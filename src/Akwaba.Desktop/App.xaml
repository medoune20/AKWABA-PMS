<Application x:Class="Akwaba.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <Color x:Key="AccentColor">#FF0F6E6E</Color>
        <SolidColorBrush x:Key="Accent" Color="{StaticResource AccentColor}"/>
        <SolidColorBrush x:Key="AccentClair" Color="#FFD7ECEC"/>
        <SolidColorBrush x:Key="Fond" Color="#FFF5F6F8"/>
        <SolidColorBrush x:Key="Carte" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="Texte" Color="#FF1A1A1A"/>
        <SolidColorBrush x:Key="TexteGris" Color="#FF6A6A6A"/>

        <Style TargetType="Button" x:Key="BtnAccent">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox" x:Key="Champ">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#FFD0D3D8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="PasswordBox" x:Key="ChampMdp">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#FFD0D3D8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </Application.Resources>
</Application>
