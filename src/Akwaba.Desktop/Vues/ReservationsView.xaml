<UserControl x:Class="Akwaba.Desktop.Vues.ReservationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="Réservations" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Texte}"/>
            <Button Content="+ Nouvelle réservation" Style="{StaticResource BtnAccent}" HorizontalAlignment="Right"
                    Click="Basculer_Click"/>
        </DockPanel>

        <Border DockPanel.Dock="Top" Background="{StaticResource Carte}" CornerRadius="12" Padding="18" Margin="0,0,0,12"
                Visibility="{Binding FormulaireVisible, Converter={StaticResource BoolVisible}}">
            <StackPanel>
                <TextBlock Text="Nouvelle réservation" FontWeight="Bold" Margin="0,0,0,10"/>
                <UniformGrid Columns="2">
                    <StackPanel Margin="0,0,8,8">
                        <TextBlock Text="Client"/>
                        <TextBox Style="{StaticResource Champ}" Text="{Binding NomClient, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="Téléphone"/>
                        <TextBox Style="{StaticResource Champ}" Text="{Binding TelClient, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,8,8">
                        <TextBlock Text="Chambre"/>
                        <ComboBox ItemsSource="{Binding Chambres}" SelectedItem="{Binding ChambreChoisie}" Padding="8,6"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="Prix / nuit (FCFA)"/>
                        <TextBox Style="{StaticResource Champ}" Text="{Binding PrixNuit, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,8,8">
                        <TextBlock Text="Arrivée"/>
                        <DatePicker SelectedDate="{Binding DateArrivee}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="Départ"/>
                        <DatePicker SelectedDate="{Binding DateDepart}"/>
                    </StackPanel>
                </UniformGrid>
                <Button Content="Créer la réservation" Style="{StaticResource BtnAccent}" HorizontalAlignment="Left"
                        Margin="0,8,0,0" Command="{Binding CreerCommand}"/>
            </StackPanel>
        </Border>

        <TextBlock DockPanel.Dock="Bottom" Text="{Binding Message}" Foreground="{StaticResource Accent}" Margin="0,8,0,0"/>

        <Border Background="{StaticResource Carte}" CornerRadius="12" Padding="6">
            <DataGrid ItemsSource="{Binding Sejours}" AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal" Background="Transparent"
                      RowBackground="Transparent" BorderThickness="0" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Client" Binding="{Binding Client}" Width="*"/>
                    <DataGridTextColumn Header="Chambre" Binding="{Binding Chambre}" Width="90"/>
                    <DataGridTextColumn Header="Période" Binding="{Binding Periode}" Width="130"/>
                    <DataGridTextColumn Header="Statut" Binding="{Binding StatutTexte}" Width="100"/>
                    <DataGridTemplateColumn Header="Actions" Width="320">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Arrivée" Margin="2" Padding="8,4"
                                            IsEnabled="{Binding PeutCheckIn}"
                                            Command="{Binding DataContext.CheckInCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="Départ" Margin="2" Padding="8,4"
                                            IsEnabled="{Binding PeutCheckOut}"
                                            Command="{Binding DataContext.CheckOutCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="Note" Margin="2" Padding="8,4"
                                            Command="{Binding DataContext.OuvrirNoteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </DockPanel>
</UserControl>
