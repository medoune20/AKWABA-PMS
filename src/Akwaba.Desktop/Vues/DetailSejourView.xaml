<UserControl x:Class="Akwaba.Desktop.Vues.DetailSejourView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <Button Content="← Retour" Command="{Binding RetourCommand}" Background="Transparent"
                    Foreground="{StaticResource Accent}" BorderThickness="0" Cursor="Hand"/>
            <TextBlock Text="{Binding Titre}" FontSize="16" FontWeight="Bold" Margin="12,0,0,0"
                       VerticalAlignment="Center" Foreground="{StaticResource Texte}"/>
        </DockPanel>

        <TextBlock DockPanel.Dock="Bottom" Text="{Binding Message}" Foreground="{StaticResource Accent}" Margin="0,8,0,0"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Note -->
            <Border Grid.Column="0" Background="{StaticResource Carte}" CornerRadius="12" Padding="14" Margin="0,0,10,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Note de chambre" FontWeight="Bold" Margin="0,0,0,8"/>
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                        <UniformGrid Columns="3">
                            <StackPanel><TextBlock Text="Total" Foreground="{StaticResource TexteGris}"/>
                                <TextBlock FontWeight="Bold"><Run Text="{Binding Total, Mode=OneWay}"/><Run Text=" FCFA"/></TextBlock></StackPanel>
                            <StackPanel><TextBlock Text="Payé" Foreground="{StaticResource TexteGris}"/>
                                <TextBlock FontWeight="Bold"><Run Text="{Binding Paye, Mode=OneWay}"/><Run Text=" FCFA"/></TextBlock></StackPanel>
                            <StackPanel><TextBlock Text="Solde" Foreground="{StaticResource TexteGris}"/>
                                <TextBlock FontWeight="Bold" Foreground="{StaticResource Accent}"><Run Text="{Binding Solde, Mode=OneWay}"/><Run Text=" FCFA"/></TextBlock></StackPanel>
                        </UniformGrid>
                        <DockPanel Margin="0,12,0,0">
                            <TextBox Style="{StaticResource Champ}" Width="180" DockPanel.Dock="Left"
                                     Text="{Binding NouvLibelle, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBox Style="{StaticResource Champ}" Width="110" Margin="8,0"
                                     Text="{Binding NouvMontant, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Content="Ajouter" Style="{StaticResource BtnAccent}" Command="{Binding AjouterLigneCommand}"/>
                        </DockPanel>
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding Lignes}" AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" Background="Transparent" RowBackground="Transparent"
                              BorderThickness="0" CanUserAddRows="False" GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Libellé" Binding="{Binding Libelle}" Width="*"/>
                            <DataGridTextColumn Header="Qté" Binding="{Binding Quantite}" Width="50"/>
                            <DataGridTextColumn Header="Montant" Binding="{Binding Montant}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Encaissement -->
            <Border Grid.Column="1" Background="{StaticResource Carte}" CornerRadius="12" Padding="14">
                <StackPanel>
                    <TextBlock Text="Encaissement" FontWeight="Bold" Margin="0,0,0,8"/>
                    <TextBlock Text="Montant (FCFA)"/>
                    <TextBox Style="{StaticResource Champ}" Text="{Binding MontantEncaisse, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="Encaisser espèces" Style="{StaticResource BtnAccent}" Margin="0,10,0,0"
                            Command="{Binding EncaisserEspecesCommand}"/>
                    <Button Content="Encaisser carte" Style="{StaticResource BtnAccent}" Margin="0,8,0,0"
                            Command="{Binding EncaisserCarteCommand}"/>
                    <TextBlock Text="Paiement mobile : disponible en ligne" Foreground="{StaticResource TexteGris}"
                               FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap"/>
                    <Separator Margin="0,12"/>
                    <Button Content="Solder la note" Command="{Binding SolderCommand}"
                            Background="Transparent" Foreground="{StaticResource Accent}" BorderThickness="1"
                            BorderBrush="{StaticResource Accent}" Padding="10,8" Cursor="Hand"/>
                    <TextBlock Text="Historique" FontWeight="Bold" Margin="0,14,0,6"/>
                    <ItemsControl ItemsSource="{Binding Paiements}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,2">
                                    <TextBlock Text="{Binding Heure}" Foreground="{StaticResource TexteGris}" FontSize="11"/>
                                    <TextBlock Text="{Binding Montant}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
