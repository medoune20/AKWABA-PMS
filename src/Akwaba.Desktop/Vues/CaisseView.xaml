<UserControl x:Class="Akwaba.Desktop.Vues.CaisseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="Caisse" FontSize="20" FontWeight="Bold"
                   Foreground="{StaticResource Texte}" Margin="0,0,0,12"/>
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding Message}" Foreground="{StaticResource Accent}" Margin="0,8,0,0"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource Carte}" CornerRadius="12" Padding="16" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="{Binding Entete}" TextWrapping="Wrap" Foreground="{StaticResource Texte}"/>
                    <Separator Margin="0,12"/>

                    <StackPanel Visibility="{Binding SessionOuverte, Converter={StaticResource BoolInvisible}}">
                        <TextBlock Text="Fonds de caisse initial (FCFA)"/>
                        <TextBox Style="{StaticResource Champ}" Text="{Binding FondsInitial, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Content="Ouvrir la session" Style="{StaticResource BtnAccent}" Margin="0,10,0,0"
                                Command="{Binding OuvrirCommand}"/>
                    </StackPanel>

                    <StackPanel Visibility="{Binding SessionOuverte, Converter={StaticResource BoolVisible}}">
                        <TextBlock Margin="0,0,0,6"><Run Text="Total espèces encaissées : "/><Run Text="{Binding TotalEspeces, Mode=OneWay}"/><Run Text=" FCFA"/></TextBlock>
                        <TextBlock Text="Montant compté à la clôture (FCFA)"/>
                        <TextBox Style="{StaticResource Champ}" Text="{Binding MontantCompte, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Content="Clôturer la session" Style="{StaticResource BtnAccent}" Margin="0,10,0,0"
                                Command="{Binding FermerCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="{StaticResource Carte}" CornerRadius="12" Padding="10">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Encaissements de la session" FontWeight="Bold" Margin="4,4,0,8"/>
                    <DataGrid ItemsSource="{Binding Paiements}" AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" Background="Transparent" RowBackground="Transparent"
                              BorderThickness="0" CanUserAddRows="False" GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Heure" Binding="{Binding Heure}" Width="140"/>
                            <DataGridTextColumn Header="Moyen" Binding="{Binding Moyen}" Width="*"/>
                            <DataGridTextColumn Header="Montant" Binding="{Binding Montant}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
