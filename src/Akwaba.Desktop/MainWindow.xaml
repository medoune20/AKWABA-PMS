<Window x:Class="Akwaba.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AKWABA Desktop" Height="640" Width="980"
        WindowStartupLocation="CenterScreen" Background="{StaticResource Fond}">
    <Window.Resources>
        <Style x:Key="VisibleSiConnecte" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding EstConnecte}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="VisibleSiDeconnecte" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding EstConnecte}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Bandeau connectivité -->
        <Border DockPanel.Dock="Top" Padding="16,10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#FFB54708"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding EstEnLigne}" Value="True">
                            <Setter Property="Background" Value="{StaticResource Accent}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel>
                <TextBlock Text="{Binding StatutConnectivite}" Foreground="White" FontWeight="Bold" FontSize="14"/>
                <TextBlock HorizontalAlignment="Right" Foreground="White" FontSize="13">
                    <Run Text="{Binding NbEnAttente, Mode=OneWay}"/><Run Text=" opération(s) en attente"/>
                </TextBlock>
            </DockPanel>
        </Border>

        <!-- Connexion -->
        <Grid Style="{StaticResource VisibleSiDeconnecte}" Margin="0,40">
            <Border Background="{StaticResource Carte}" CornerRadius="12" Width="420" Padding="28"
                    HorizontalAlignment="Center" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="AKWABA Desktop" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource Accent}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Réception &amp; caisse — poste hôtel" Foreground="{StaticResource TexteGris}"
                               HorizontalAlignment="Center" Margin="0,2,0,20"/>
                    <TextBlock Text="Adresse e-mail" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource Champ}" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="Mot de passe" Margin="0,14,0,4"/>
                    <PasswordBox x:Name="Mdp" Style="{StaticResource ChampMdp}"/>
                    <TextBlock Text="{Binding MessageErreur}" Foreground="#FFB42318" Margin="0,12,0,0" TextWrapping="Wrap"/>
                    <Button x:Name="BtnEnLigne" Content="Se connecter (en ligne)" Style="{StaticResource BtnAccent}"
                            Margin="0,18,0,0" Click="BtnEnLigne_Click"/>
                    <Button x:Name="BtnHorsLigne" Content="Déverrouiller (hors ligne)" Margin="0,10,0,0"
                            Background="Transparent" Foreground="{StaticResource Accent}" BorderThickness="0"
                            Cursor="Hand" Click="BtnHorsLigne_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Espace connecté (socle ; les écrans réception/caisse arrivent à l'incrément suivant) -->
        <Grid Style="{StaticResource VisibleSiConnecte}" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <DockPanel Grid.Row="0">
                <StackPanel>
                    <TextBlock Text="{Binding TenantNom}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Texte}"/>
                    <TextBlock Text="{Binding NomComplet}" Foreground="{StaticResource TexteGris}"/>
                </StackPanel>
                <Button Content="Déconnexion" HorizontalAlignment="Right" Background="Transparent"
                        Foreground="{StaticResource Accent}" BorderThickness="0" Cursor="Hand" Click="BtnDeco_Click"/>
            </DockPanel>

            <Border Grid.Row="1" Background="{StaticResource Carte}" CornerRadius="12" Padding="20" Margin="0,16,0,0">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top">
                        <TextBlock Text="Synchronisation" FontSize="16" FontWeight="Bold"/>
                        <Button Content="Synchroniser maintenant" Style="{StaticResource BtnAccent}"
                                HorizontalAlignment="Right" Command="{Binding SynchroniserCommand}"/>
                    </DockPanel>
                    <TextBlock DockPanel.Dock="Top" Margin="0,8,0,8" Foreground="{StaticResource TexteGris}">
                        <Run Text="{Binding NbEnAttente, Mode=OneWay}"/><Run Text=" opération(s) locale(s) en attente d'envoi."/>
                    </TextBlock>
                    <TextBox Text="{Binding Journal, Mode=OneWay}" IsReadOnly="True" FontFamily="Consolas" FontSize="12"
                             VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" BorderThickness="1" BorderBrush="#FFE2E5EA"/>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
